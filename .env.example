# =============================================================================
# SFLL — League Management System (v2) — Environment Variables
# =============================================================================
# Copy to .env and adjust values for your environment.
# Ports default to 5433/6380/8001 to avoid conflicts with other projects.
# =============================================================================

# ---------------------------------------------------------------------------
# Django Core
# ---------------------------------------------------------------------------
# Generate a real key for production: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=django-insecure-change-this-in-production

# Set to False in production
DEBUG=True

# Comma-separated list of hosts. Include your domain(s) in production.
ALLOWED_HOSTS=localhost,127.0.0.1

# Base URL for absolute links in emails and QR codes (no trailing slash)
SITE_URL=https://sfll.org

# ---------------------------------------------------------------------------
# Database (PostgreSQL 16)
# ---------------------------------------------------------------------------
DB_NAME=sfll
DB_USER=sfll
DB_PASSWORD=dev_password
DB_HOST=db
DB_PORT=5432

# Full connection URL (used by Django). For local dev without Docker, use:
# DATABASE_URL=postgresql://sfll:dev_password@localhost:5433/sfll
DATABASE_URL=postgresql://sfll:dev_password@db:5432/sfll

# ---------------------------------------------------------------------------
# Redis / Celery
# ---------------------------------------------------------------------------
# Redis instance for caching and Channels
REDIS_URL=redis://redis:6379/1

# Celery broker and result backend
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# ---------------------------------------------------------------------------
# Host Port Mapping (Docker Compose)
# ---------------------------------------------------------------------------
# These map host ports to container ports to avoid conflicts with other
# projects running on the same machine (e.g., Goodbay on 5432/6379/8000).
#
# DB_PORT: host port -> container 5432 (Postgres)
DB_PORT=5433

# REDIS_PORT: host port -> container 6379 (Redis)
REDIS_PORT=6380

# WEB_PORT: host port -> container 8000 (Django)
WEB_PORT=8001

# ---------------------------------------------------------------------------
# Email
# ---------------------------------------------------------------------------
# Dev default: prints to console. For production, configure SMTP:
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend

# Uncomment and configure for production SMTP:
# EMAIL_HOST=smtp.example.com
# EMAIL_PORT=587
# EMAIL_HOST_USER=noreply@sfll.org
# EMAIL_HOST_PASSWORD=your-smtp-password
# EMAIL_USE_TLS=True
# DEFAULT_FROM_EMAIL=SFLL <noreply@sfll.org>

# ---------------------------------------------------------------------------
# SportsConnect Integration
# ---------------------------------------------------------------------------
# URL for automated CSV report downloads (configured per league in admin)
# SPORTSCONNECT_REPORT_URL=https://...

# ---------------------------------------------------------------------------
# Seed Data
# ---------------------------------------------------------------------------
# Set to true to run seed data script on first startup (Docker entrypoint)
SETUP_SEED=false
