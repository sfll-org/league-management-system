# =============================================================================
# SFLL Player Database — Environment Variables
# =============================================================================
# Copy to .env and adjust values for your environment.
# =============================================================================

# Django
SECRET_KEY=django-insecure-change-this-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database
DB_NAME=sfll
DB_USER=sfll
DB_PASSWORD=dev_password
DB_HOST=db
DB_PORT=5432
DATABASE_URL=postgresql://sfll:dev_password@db:5432/sfll

# Redis / Celery
REDIS_URL=redis://redis:6379/1
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# Email (dev: console backend)
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
# EMAIL_HOST=smtp.example.com
# EMAIL_PORT=587
# EMAIL_HOST_USER=
# EMAIL_HOST_PASSWORD=
# EMAIL_USE_TLS=True
# DEFAULT_FROM_EMAIL=noreply@sfll.org

# Seed data
SETUP_SEED=false
